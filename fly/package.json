{
  "name": "pbot-crawler",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "Apache 2",
  "scripts": {
    "generate": "prisma generate",
    "dev": "dotenv -- astro dev",
    "test": "pnpm generate && pnpm astro check && DATABASE_URL=file:./test.db prisma db push --force-reset && DATABASE_URL=file:./test.db vitest run",
    "test:watch": "pnpm generate && pnpm astro check && DATABASE_URL=file:./test.db prisma db push --force-reset && DATABASE_URL=file:./test.db vitest watch",
    "start": "dotenv -- node ./dist/server/entry.mjs",
    "start:prod": "prisma migrate deploy && node ./dist/server/entry.mjs",
    "build": "pnpm generate && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@google-cloud/bigquery": "^6.0.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "astro": "^7.0.7",
    "debug": "^4.3.4",
    "handlebars": "^4.7.7",
    "hast-util-from-html": "^2.0.3",
    "hast-util-to-mdast": "^10.1.2",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "prisma": "^7.8.0",
    "resend": "^6.17.2",
    "robots-parser": "^3.0.1",
    "temporal-polyfill": "^1.0.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/debug": "^4.1.7",
    "@types/node": "^24.13.3",
    "dotenv-cli": "^11.0.0",
    "nock": "^14.0.16",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
